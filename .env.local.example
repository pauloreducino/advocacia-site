# WordPress Headless CMS
# URL base da API REST do WordPress (sem barra no final)
WORDPRESS_API_URL=http://localhost/wp-json/wp/v2

# Chave secreta para o webhook de revalidação (gere uma string aleatória)
REVALIDATE_SECRET=sua_chave_secreta_aqui

# URL pública do site Next.js (sem barra no final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Número do WhatsApp (apenas dígitos, com código do país)
NEXT_PUBLIC_WA_NUMBER=5511999999999

# Mensagem padrão do WhatsApp (será codificada como URL)
NEXT_PUBLIC_WA_MESSAGE=Olá, gostaria de agendar uma consulta.
